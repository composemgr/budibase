# Budibase - Low-code platform for building internal tools
# Copy to app.env and fill in your values

# Timezone
TZ=America/New_York

# Hostname / domain
BASE_HOST_NAME=$HOSTNAME
BASE_DOMAIN_NAME=example.com

# Admin credentials (used for Budibase login, CouchDB, and MinIO)
APP_ADMIN_USER=admin
APP_ADMIN_PASS=changeme_admin_password

# CouchDB admin (used for internal database access)
DB_ADMIN_USER=budibase
DB_ADMIN_PASS=changeme_admin_password

# Application secrets (must be at least 32 characters)
APP_JWT_TOKEN=changeme_jwt_secret_min_32_chars
ENCRYPTION_KEY=changeme_encryption_key_min_32_chars
APP_API_TOKEN=changeme_internal_api_key_min_32_chars
